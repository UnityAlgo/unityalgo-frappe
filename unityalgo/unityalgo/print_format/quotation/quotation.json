 "doc_type": "Quotation",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<div style=\"display:flex;justify-content: space-between;\">\n    <div>\n        {{letter_head }}\n    </div>\n\n    <div class=\"text-right\">\n        <div style=\"font-size: 1rem;font-weight: 600;\">Quotation</div>\n        <br>\n        <strong>Ref #:</strong> {{ doc.name }}<br>\n        <strong>Date:</strong> {{ doc.get_formatted(\"transaction_date\") }}<br>\n        <strong>Valid Until:</strong> {{ doc.get_formatted(\"valid_till\") or \"N/A\" }}\n    </div>\n</div>\n\n\n\n<div class=\"row info-block\">\n    <div class=\"col-xs-6\">\n        <div class=\"info-label\">Quotation To:</div>\n        <strong>{{ doc.customer_name }}</strong><br>\n        {{ doc.address_display or '' }}\n        {% if doc.contact_display %}\n        <br>Attn: {{ doc.contact_display }}\n        {% endif %}\n    </div>\n    <div class=\"col-xs-6 text-right\">\n        {% if doc.payment_terms_template %}\n        <div class=\"info-label\">Payment Terms:</div>\n        {{ doc.payment_terms_template }}\n        {% endif %}\n    </div>\n</div>\n\n<div>\n    <table class=\"table table-bordered\">\n        <thead>\n            <tr>\n                <th style=\"width:5%;\">#</th>\n                <th style=\"width:75%;\">Description</th>\n                <th style=\"width:20%;\" class=\"text-right\">Amount</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for item in doc.items %}\n            <tr>\n                <td>{{ loop.index }}</td>\n                <td>\n                    <strong>{{ item.item_name }}</strong>\n                    {% if item.description != item.item_name %}\n                    <br><small class=\"text-muted\">{{ item.description }}</small>\n                    {% endif %}\n                </td>\n                <td class=\"text-right\">{{ item.get_formatted(\"amount\") }}</td>\n            </tr>\n            {% endfor %}\n        </tbody>\n    </table>\n\n</div>\n\n<div class=\"row\">\n    <div class=\"col-xs-7\">\n        <div style=\"margin-top: 20px;\">\n            <strong>Amount in Words:</strong><br>\n            <i>{{ doc.in_words }}</i>\n        </div>\n    </div>\n\n    <div class=\"col-xs-5\">\n        <div class=\"totals-area\">\n            <div class=\"totals-row\">\n                <span><b>Net Total:</b></span>\n                <span>{{ doc.get_formatted(\"total\") }}</span>\n            </div>\n\n            {% for tax in doc.taxes %}\n            {% if tax.tax_amount > 0 %}\n            <div class=\"totals-row\">\n                <span><b>{{ tax.description }} (@ {{ tax.rate }}%):</b></span>\n                <span>{{ tax.get_formatted(\"tax_amount\") }}</span>\n            </div>\n            {% endif %}\n            {% endfor %}\n\n            {% if doc.discount_amount %}\n            <div class=\"totals-row\">\n                <span><b>Discount:</b></span>\n                <span>-{{ doc.get_formatted(\"discount_amount\") }}</span>\n            </div>\n            {% endif %}\n\n            <div class=\"grand-total totals-row\">\n                <span><b>Grand Total:</b></span>\n                <span>{{ doc.get_formatted(\"grand_total\") }}</span>\n            </div>\n        </div>\n    </div>\n</div>\n\n<br>\n<br>\n\n<div class=\"terms-section\">\n    {% if doc.terms %}\n    <strong>Terms & Conditions:</strong><br>\n    {{ doc.terms }}\n    {% endif %}\n<!-- \n    <br><br><br>\n    <div class=\"row\">\n        <div class=\"col-xs-6\">\n            ___________________________<br>\n            Authorized Signature<br>\n            <strong>{{ doc.company }}</strong>\n        </div>\n        <div class=\"col-xs-6 text-right\">\n            ___________________________<br>\n            Accepted By<br>\n            <strong>{{ doc.customer_name }}</strong>\n        </div>\n    </div> -->\n</div>",

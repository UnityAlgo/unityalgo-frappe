 "css": ".print-format {\n    color: #000 !important;\n}\n\n.table {\n    width: 100%;\n    table-layout: fixed;\n}\n\n.print-format td,\n.print-format th {\n    padding: 5px !important;\n    font-size: .75rem;\n    color: #000;\n}\n\n.table-bordered th, \n.table-bordered td {\n    border: 1px solid #e7e7e7 !important;\n}\n.print-format th {\n    background-color: #e7e7e7;\n    font-weight: 600;\n}",
